# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (Prisma)
# Replace credentials if running outside docker compose environment
DATABASE_URL="postgresql://postgres:postgrespassword@localhost:5432/propx_db?schema=public"

# Authentication Security
JWT_SECRET="super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# AI Configuration
AI_PROVIDER="mock" # "anthropic" or "mock"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-sonnet-20240620"
